# ── Local development only ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your key.
# This variable is ONLY used in local dev (import.meta.env.DEV).
# In production (Vercel), set ANTHROPIC_API_KEY as a server env variable.
# It will NEVER be bundled into the frontend build.

VITE_ANTHROPIC_API_KEY=sk-ant-...your-key-here...
