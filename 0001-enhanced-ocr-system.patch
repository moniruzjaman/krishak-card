+   PHOTO CAPTURE
+   ============================================ */
+.photo-capture-area {
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  gap: 20px;
+}
+
+.photo-frame {
+  width: 280px;
+  height: 280px;
+  border-radius: 50%;
+  border: 4px solid var(--border);
+  overflow: hidden;
+  position: relative;
+  background: #f5f5f5;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.photo-frame.pass { border-color: var(--success); }
+.photo-frame.warning { border-color: var(--warning); }
+.photo-frame.fail { border-color: var(--danger); }
+
+.photo-frame img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+}
+
+.photo-placeholder {
+  text-align: center;
+  color: var(--text-secondary);
+}
+
+.placeholder-icon {
+  font-size: 4rem;
+  display: block;
+  margin-bottom: 8px;
+}
+
+.quality-overlay {
+  position: absolute;
+  bottom: 0;
+  left: 0;
+  right: 0;
+  background: rgba(0,0,0,0.8);
+  color: white;
+  padding: 12px;
+  border-radius: 0 0 50% 50%;
+}
+
+.quality-score {
+  text-align: center;
+  margin-bottom: 8px;
+}
+
+.score-value {
+  font-size: 1.5rem;
+  font-weight: 700;
+}
+
+.score-label {
+  font-size: 0.8rem;
+  opacity: 0.8;
+}
+
+.quality-bars {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+
+.quality-bar {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  font-size: 0.7rem;
+}
+
+.bar-name {
+  width: 60px;
+  text-transform: capitalize;
+}
+
+.bar-fill {
+  flex: 1;
+  height: 6px;
+  background: rgba(255,255,255,0.2);
+  border-radius: 3px;
+  overflow: hidden;
+}
+
+.bar-inner {
+  height: 100%;
+  border-radius: 3px;
+  transition: width 0.5s ease;
+}
+
+.quality-bar.pass .bar-inner { background: #4caf50; }
+.quality-bar.warning .bar-inner { background: #ff9800; }
+.quality-bar.fail .bar-inner { background: #f44336; }
+
+.photo-actions {
+  display: flex;
+  gap: 12px;
+  flex-wrap: wrap;
+  justify-content: center;
+}
+
+.quality-guidance {
+  max-width: 400px;
+  padding: 20px;
+  border-radius: var(--radius-md);
+  text-align: left;
+}
+
+.quality-guidance.fail {
+  background: #ffebee;
+  border: 1px solid #ef9a9a;
+}
+
+.quality-guidance.warning {
+  background: #fff8e1;
+  border: 1px solid #ffe082;
+}
+
+.quality-guidance h4 {
+  margin-bottom: 8px;
+}
+
+.quality-guidance ul {
+  margin-top: 8px;
+  padding-left: 20px;
+}
+
+.quality-guidance li {
+  margin-bottom: 4px;
+  font-size: 0.9rem;
