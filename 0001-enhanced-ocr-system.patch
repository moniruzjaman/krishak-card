+export class BanglaCorrector {
+  constructor() {
+    this.dictionary = COMMON_NAMES;
+    this.normalizationMap = CHAR_NORMALIZATION;
+    this.levenshteinCache = new Map();
+    this.maxCacheSize = 10000;
+  }
