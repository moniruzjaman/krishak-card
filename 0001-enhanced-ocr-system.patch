+
+.quick-select p {
+  font-size: 0.9rem;
+  margin-bottom: 8px;
+  color: var(--text-secondary);
+}
+
+.quick-villages {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+}
+
+.quick-village-btn {
+  padding: 8px 16px;
+  background: white;
+  border: 1px solid var(--info);
+  color: var(--info);
+  border-radius: 20px;
+  cursor: pointer;
+  font-size: 0.85rem;
+  transition: var(--transition);
+}
+
+.quick-village-btn:hover {
+  background: var(--info);
+  color: white;
+}
