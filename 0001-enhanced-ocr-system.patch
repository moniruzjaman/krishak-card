+    const standaloneVowelRegex = new RegExp(`(^|\\s)[${VOWEL_SIGNS.join('')}]+(?=\\s|$)`, 'g');
+    normalized = normalized.replace(standaloneVowelRegex, ' ');
+
+    return normalized.trim();
+  }
