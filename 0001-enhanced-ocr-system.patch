+// BANGLA VOWEL SIGN COMBINATIONS
+// ============================================
+const VOWEL_SIGNS = ['া', 'ি', 'ী', 'ু', 'ূ', 'ৃ', 'ে', 'ৈ', 'ো', 'ৌ', 'ং', 'ঃ', 'ঁ'];
+const HASANT = '্';
